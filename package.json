{
	"name": "multisource-api",
	"version": "4.0.0",
	"description": "Zero-dependency serverless API to aggregate HLS video streams from multiple sources for any TMDB movie or TV show",
	"main": "raw-api.js",
	"scripts": {
		"start": "node raw-api.js --server",
		"test": "node test.js",
		"cli": "node raw-api.js --tmdb=24428",
		"health": "node scripts/source-health.js"
	},
	"keywords": [
		"streaming",
		"hls",
		"m3u8",
		"tmdb",
		"aggregator",
		"serverless",
		"video",
		"cloudstream",
		"skystream",
		"nuvio",
		"stremio"
	],
	"author": "thegnsme",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thegnsme/multisource-api.git"
	},
	"bugs": {
		"url": "https://github.com/thegnsme/multisource-api/issues"
	},
	"homepage": "https://github.com/thegnsme/multisource-api#readme",
	"engines": {
		"node": ">=16.0.0"
	},
	"optionalDependencies": {
		"axios": "^1.7.0"
	},
	"files": [
		"raw-api.js",
		"sources/",
		"scripts/",
		"test.js",
		"SOURCE_HEALTH.md",
		"README.md"
	]
}
